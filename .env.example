# =========================================================
# Openclaw Release — Environment Variables
# Copy file này thành `.env` rồi điền giá trị thật.
# KHÔNG commit file .env lên git.
# =========================================================

# --- Ports expose ra host ---
NGINX_PORT=9504
NINEROUTER_PORT=20128

# --- Token dùng giữa zalo connector và ai-bot gateway ---
# Sinh bằng: openssl rand -hex 24
OPENCLAW_TOKEN=change_me_to_random_hex_token

# --- API keys tuỳ chọn cho ai-bot ---
# Chỉ điền nếu bot cần gọi trực tiếp (thông thường đã đi qua 9router).
GOOGLE_API_KEY=
TELEGRAM_BOT_TOKEN=
