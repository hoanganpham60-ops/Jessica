<%- include('_header', { title: 'Đổi mật khẩu', active: 'password', flash: flash }) %>
<h1>Đổi mật khẩu admin</h1>
<% if (error) { %><div class="flash err"><%= error %></div><% } %>
<form method="post" class="form">
  <label>Mật khẩu hiện tại</label>
  <input type="password" name="current" required>
  <label>Mật khẩu mới</label>
  <input type="password" name="next" required minlength="6">
  <label>Nhập lại</label>
  <input type="password" name="confirm" required minlength="6">
  <button class="primary" type="submit">Đổi</button>
</form>
<%- include('_footer') %>
