<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= title %> — Openclaw Setup</title>
<link rel="stylesheet" href="/setup/static/style.css">
</head>
<body>
<% if (typeof nav === 'undefined' || nav !== false) { %>
<header class="topbar">
  <div class="brand">🦊 Openclaw Setup</div>
  <nav>
    <a href="/setup" <%= active==='home'?'class="on"':'' %>>Dashboard</a>
    <a href="/setup/general" <%= active==='general'?'class="on"':'' %>>General</a>
    <a href="/setup/providers" <%= active==='providers'?'class="on"':'' %>>Providers</a>
    <a href="/setup/channels" <%= active==='channels'?'class="on"':'' %>>Channels</a>
    <a href="/setup/memory" <%= active==='memory'?'class="on"':'' %>>Memory</a>
    <a href="/setup/password" <%= active==='password'?'class="on"':'' %>>Password</a>
  </nav>
  <form method="post" action="/setup/logout" class="logout">
    <button type="submit">Logout</button>
  </form>
</header>
<% } %>
<main class="container">
<% if (typeof flash !== 'undefined' && flash) { %>
  <div class="flash <%= flash.type %>"><%= flash.msg %></div>
<% } %>
<%- body %>
</main>
</body>
</html>
